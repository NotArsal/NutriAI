# backend/.env.example
# Copy this to backend/.env and fill in real values for local development.
# NEVER commit the actual .env file.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutriplanner

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# or:           openssl rand -hex 32
SECRET_KEY=change-me-generate-a-real-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
